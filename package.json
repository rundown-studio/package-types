{
  "name": "@rundown-studio/types",
  "version": "1.12.0",
  "description": "Shared types for the Rundown Studio project",
  "license": "ISC",
  "author": "Lukas Hermann <hey@lukashermann.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rundown-studio/package-types.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "vitest",
    "test:ci": "vitest --run --no-color",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@rundown-studio/consts": "0.7.2",
    "date-fns": "^4.1.0"
  }
}
